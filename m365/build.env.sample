# Build-time substitution values for the Planetary Explorer M365 Teams app.
#
# Copy this to `build.env` and fill in real values, OR set the same names
# as environment variables — env vars override the file.
#
# Do NOT commit `build.env` to source control (already in .gitignore).

# --- Entra ---
TENANT_ID={{TENANT_ID}}
APP_CLIENT_ID={{APP_CLIENT_ID}}

# --- Backend ---
# Base URL of the Planetary Explorer container-app (no trailing slash, no scheme prefix)
API_BASE_URL=planetaryexplorer-dev.azurewebsites.net
# Same value as a bare domain (auto-derived if omitted)
API_DOMAIN=planetaryexplorer-dev.azurewebsites.net

# --- Web UI ---
WEB_UI_BASE_URL=planetaryexplorer-dev.azurewebsites.net
WEB_UI_DOMAIN=planetaryexplorer-dev.azurewebsites.net

# --- App-level identity (used in privacy/terms URLs) ---
APP_DOMAIN=planetaryexplorer.example.com

# --- Teams app id (generate a fresh GUID per logical app) ---
TEAMS_APP_ID={{TEAMS_APP_ID}}

# --- OAuth client registration id from Teams Developer Portal ---
# See docs/entra-app-registration.md step 6.
OAUTH_CLIENT_REGISTRATION_ID={{OAUTH_CLIENT_REGISTRATION_ID}}
